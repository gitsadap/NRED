{% extends "layout.html" %}

{% block content %}
<!-- Performance & Font Loading -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link
    href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;500;700;900&family=Space+Grotesk:wght@400;700&display=swap"
    rel="stylesheet">

<!-- Swiper CSS -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />

<style>
    /* Fonts */
    .font-outfit {
        font-family: 'Outfit', 'Prompt', sans-serif;
    }

    .font-space {
        font-family: 'Space Grotesk', monospace;
    }

    /* GPU Acceleration */
    .gpu {
        transform: translateZ(0);
        will-change: transform;
    }

    /* Hide Scrollbar */
    .hide-scrollbar::-webkit-scrollbar {
        display: none;
    }

    .hide-scrollbar {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }

    /* Text Gradient */
    .text-gradient {
        background: linear-gradient(135deg, #10b981 0%, #06b6d4 50%, #3b82f6 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    /* Glass Morphism */
    .glass {
        background: rgba(255, 255, 255, 0.08);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.15);
    }

    .glass-dark {
        background: rgba(0, 0, 0, 0.3);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.1);
    }

    /* Glow Effects */
    .glow-green {
        box-shadow: 0 0 30px rgba(16, 185, 129, 0.5),
            0 0 60px rgba(16, 185, 129, 0.3);
    }

    .glow-blue {
        box-shadow: 0 0 30px rgba(59, 130, 246, 0.5),
            0 0 60px rgba(59, 130, 246, 0.3);
    }

    .glow-cyan {
        box-shadow: 0 0 30px rgba(6, 182, 212, 0.5),
            0 0 60px rgba(6, 182, 212, 0.3);
    }

    /* Animations */
    @keyframes float {

        0%,
        100% {
            transform: translateY(0px) rotate(0deg);
        }

        25% {
            transform: translateY(-20px) rotate(5deg);
        }

        50% {
            transform: translateY(-10px) rotate(-5deg);
        }

        75% {
            transform: translateY(-15px) rotate(3deg);
        }
    }

    @keyframes spin-slow {
        from {
            transform: rotate(0deg);
        }

        to {
            transform: rotate(360deg);
        }
    }

    @keyframes spin-reverse {
        from {
            transform: rotate(360deg);
        }

        to {
            transform: rotate(0deg);
        }
    }

    @keyframes pulse-glow {

        0%,
        100% {
            opacity: 0.5;
            filter: blur(10px);
        }

        50% {
            opacity: 1;
            filter: blur(15px);
        }
    }

    @keyframes slide-in-left {
        from {
            transform: translateX(-100px);
            opacity: 0;
        }

        to {
            transform: translateX(0);
            opacity: 1;
        }
    }

    @keyframes slide-in-right {
        from {
            transform: translateX(100px);
            opacity: 0;
        }

        to {
            transform: translateX(0);
            opacity: 1;
        }
    }

    .animate-float {
        animation: float 6s ease-in-out infinite;
    }

    .animate-spin-slow {
        animation: spin-slow 20s linear infinite;
    }

    .animate-spin-reverse {
        animation: spin-reverse 15s linear infinite;
    }

    .animate-pulse-glow {
        animation: pulse-glow 3s ease-in-out infinite;
    }

    /* Gradient Mesh */
    .gradient-mesh {
        background:
            radial-gradient(circle at 20% 30%, rgba(16, 185, 129, 0.15) 0%, transparent 50%),
            radial-gradient(circle at 80% 70%, rgba(59, 130, 246, 0.15) 0%, transparent 50%),
            radial-gradient(circle at 50% 50%, rgba(6, 182, 212, 0.1) 0%, transparent 50%);
    }

    /* Vector Icons */
    .vector-icon {
        position: absolute;
        opacity: 0.3;
        filter: drop-shadow(0 0 10px currentColor);
    }

    /* Swiper */
    .swiper {
        width: 100%;
        height: 100%;
    }

    .swiper-button-next,
    .swiper-button-prev {
        color: white;
        background: rgba(0, 0, 0, 0.5);
        width: 50px;
        height: 50px;
        border-radius: 50%;
        backdrop-filter: blur(10px);
    }

    .swiper-button-next:after,
    .swiper-button-prev:after {
        font-size: 20px;
    }

    /* Responsive */
    @media (max-width: 768px) {
        .hero-title {
            font-size: 2.5rem !important;
        }

        .vector-icon {
            opacity: 0.2;
        }
    }
</style>

{% set hero_mode = settings.get('hero_mode', 'video') %}
{% set hero_title = settings.get('hero_title', 'Innovation in Agriculture & Environment') %}
{% set hero_subtitle = settings.get('hero_subtitle', 'Empowering the future through sustainable practices') %}

<!-- ========================================
     HERO SECTION - Premium Design
     ======================================== -->
<section
    class="hero-section relative min-h-screen w-full overflow-hidden bg-gradient-to-br from-gray-900 via-slate-900 to-black text-white flex items-center justify-center font-outfit">

    <!-- Video Background -->
    <div class="absolute inset-0 z-0">
        <video autoplay loop muted playsinline class="w-full h-full object-cover opacity-20 gpu">
            <source src="/assets/images/NRED-bg.mp4" type="video/mp4">
        </video>
        <div class="absolute inset-0 bg-gradient-to-b from-black/50 via-transparent to-black/70"></div>
    </div>

    <!-- Animated Gradient Orbs -->
    <div class="absolute inset-0 z-0 gradient-mesh">
        <div class="absolute top-[-10%] left-[-5%] w-96 h-96 bg-green-500/20 rounded-full blur-3xl animate-float"></div>
        <div class="absolute bottom-[-10%] right-[-5%] w-96 h-96 bg-blue-500/20 rounded-full blur-3xl animate-float"
            style="animation-delay: 2s;"></div>
        <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-80 h-80 bg-cyan-500/15 rounded-full blur-3xl animate-float"
            style="animation-delay: 1s;"></div>
    </div>

    <!-- Grid Pattern Overlay -->
    <div class="absolute inset-0 z-0 opacity-10" style="background-image: linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px);
                background-size: 50px 50px;">
    </div>

    <!-- Main Hero Content -->
    <div class="relative z-10 container mx-auto px-4 py-20">

        <!-- NRED Display -->
        <div class="nred-container max-w-6xl mx-auto">

            <!-- Row 1: N -->
            <div class="nred-row flex items-center justify-center md:justify-start mb-4 md:mb-6 group"
                data-aos="fade-right" data-aos-duration="1000" data-aos-delay="100">

                <!-- Letter Box -->
                <div class="letter-box relative">
                    <div class="w-20 h-20 md:w-32 md:h-32 lg:w-40 lg:h-40 
                                bg-white rounded-3xl md:rounded-[2rem] 
                                flex items-center justify-center 
                                shadow-2xl glow-green
                                transform transition-all duration-500 hover:scale-110 hover:rotate-6
                                gpu">
                        <span class="text-4xl md:text-6xl lg:text-8xl font-black text-gray-900">N</span>
                    </div>

                    <!-- Floating Vector -->
                    <div
                        class="vector-icon hidden md:block absolute -right-20 top-1/2 -translate-y-1/2 text-green-400 animate-spin-slow">
                        <svg class="w-16 h-16 lg:w-20 lg:h-20" viewBox="0 0 24 24" fill="currentColor">
                            <path
                                d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                        </svg>
                    </div>
                </div>

                <!-- Expanded Text -->
                <div class="expansion-text ml-4 md:ml-8 overflow-hidden">
                    <h2 class="text-3xl md:text-5xl lg:text-7xl font-black text-white tracking-tight uppercase
                               transform transition-all duration-500 group-hover:translate-x-2">
                        ATURAL
                    </h2>
                </div>
            </div>

            <!-- Row 2: R -->
            <div class="nred-row flex items-center justify-center md:justify-start ml-0 md:ml-20 mb-4 md:mb-6 group"
                data-aos="fade-left" data-aos-duration="1000" data-aos-delay="200">

                <!-- Letter Box -->
                <div class="letter-box relative">
                    <div class="w-20 h-20 md:w-32 md:h-32 lg:w-40 lg:h-40 
                                glass rounded-3xl md:rounded-[2rem]
                                flex items-center justify-center 
                                shadow-2xl glow-green border-2 border-green-500/50
                                transform transition-all duration-500 hover:scale-110 hover:-rotate-6
                                gpu">
                        <span class="text-4xl md:text-6xl lg:text-8xl font-black text-green-400">R</span>
                    </div>

                    <!-- Floating Vector -->
                    <div
                        class="vector-icon hidden md:block absolute -left-20 top-1/2 -translate-y-1/2 text-green-300 animate-spin-reverse">
                        <svg class="w-14 h-14 lg:w-18 lg:h-18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2">
                            <circle cx="12" cy="12" r="10" />
                            <path
                                d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
                        </svg>
                    </div>
                </div>

                <!-- Expanded Text -->
                <div class="expansion-text ml-4 md:ml-8 overflow-hidden">
                    <h2 class="text-3xl md:text-5xl lg:text-7xl font-black text-white/95 tracking-tight uppercase
                               transform transition-all duration-500 group-hover:translate-x-2">
                        ESOURCES
                    </h2>
                </div>
            </div>

            <!-- Row 3: E -->
            <div class="nred-row flex items-center justify-center md:justify-start ml-0 md:ml-40 mb-4 md:mb-6 group"
                data-aos="fade-right" data-aos-duration="1000" data-aos-delay="300">

                <!-- Letter Box -->
                <div class="letter-box relative">
                    <div class="w-20 h-20 md:w-32 md:h-32 lg:w-40 lg:h-40 
                                bg-white rounded-full
                                flex items-center justify-center 
                                shadow-2xl glow-blue
                                transform transition-all duration-500 hover:scale-110 hover:rotate-12
                                gpu">
                        <span class="text-4xl md:text-6xl lg:text-8xl font-black text-blue-600">E</span>
                    </div>

                    <!-- Floating Vector -->
                    <div class="vector-icon hidden md:block absolute -right-24 -top-10 text-blue-400 animate-float">
                        <svg class="w-20 h-20 lg:w-24 lg:h-24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="1.5">
                            <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" />
                        </svg>
                    </div>
                </div>

                <!-- Expanded Text -->
                <div class="expansion-text ml-4 md:ml-8 overflow-hidden">
                    <h2 class="text-3xl md:text-5xl lg:text-7xl font-black text-white/95 tracking-tight uppercase
                               transform transition-all duration-500 group-hover:translate-x-2">
                        NVIRONMENT
                    </h2>
                </div>
            </div>

            <!-- Row 4: D -->
            <div class="nred-row flex items-center justify-center md:justify-start ml-0 md:ml-60 mb-8 md:mb-12 group"
                data-aos="fade-left" data-aos-duration="1000" data-aos-delay="400">

                <!-- Letter Box -->
                <div class="letter-box relative">
                    <div class="w-20 h-20 md:w-32 md:h-32 lg:w-40 lg:h-40 
                                glass-dark rounded-3xl md:rounded-[2rem]
                                flex items-center justify-center 
                                shadow-2xl glow-cyan border-4 border-white/30
                                transform transition-all duration-500 hover:scale-110 hover:-rotate-3
                                gpu">
                        <span class="text-4xl md:text-6xl lg:text-8xl font-black text-white">D</span>
                    </div>

                    <!-- Floating Vector -->
                    <div class="vector-icon hidden md:block absolute -left-16 -bottom-12 text-cyan-400 animate-spin-slow"
                        style="animation-duration: 25s;">
                        <svg class="w-16 h-16 lg:w-20 lg:h-20" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4z" />
                        </svg>
                    </div>
                </div>

                <!-- Expanded Text -->
                <div class="expansion-text ml-4 md:ml-8 overflow-hidden">
                    <h2 class="text-3xl md:text-5xl lg:text-7xl font-black text-white/90 tracking-tight uppercase
                               transform transition-all duration-500 group-hover:translate-x-2">
                        EPARTMENT
                    </h2>
                </div>
            </div>

        </div>

        <!-- Subtitle -->
        <div class="text-center max-w-4xl mx-auto mt-12 md:mt-16" data-aos="fade-up" data-aos-delay="500">
            <div class="glass-dark rounded-3xl px-6 py-4 md:px-10 md:py-6 inline-block">
                <p class="text-base md:text-xl lg:text-2xl font-light text-gray-200 leading-relaxed font-space">
                    ภาควิชาทรัพยากรธรรมชาติและสิ่งแวดล้อม
                    <span class="hidden md:inline text-green-400 mx-3">●</span>
                    <br class="md:hidden">
                    คณะเกษตรศาสตร์ฯ มหาวิทยาลัยนเรศวร
                </p>
            </div>
        </div>

        <!-- Scroll Indicator -->
        <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-3" data-aos="fade-up"
            data-aos-delay="700">
            <div class="w-6 h-10 border-2 border-white/40 rounded-full flex justify-center pt-2">
                <div class="w-1 h-2 bg-white rounded-full animate-bounce"></div>
            </div>
            <span class="text-xs text-white/60 uppercase tracking-widest font-space">Scroll</span>
        </div>

    </div>

    <!-- Decorative Particles -->
    <div class="absolute inset-0 z-0 overflow-hidden pointer-events-none">
        <div class="particle absolute w-2 h-2 bg-green-400/30 rounded-full animate-float" style="top: 20%; left: 15%;">
        </div>
        <div class="particle absolute w-1 h-1 bg-blue-400/30 rounded-full animate-float"
            style="top: 40%; left: 85%; animation-delay: 1s;"></div>
        <div class="particle absolute w-3 h-3 bg-cyan-400/30 rounded-full animate-float"
            style="top: 70%; left: 25%; animation-delay: 2s;"></div>
        <div class="particle absolute w-1 h-1 bg-green-400/30 rounded-full animate-float"
            style="top: 85%; left: 75%; animation-delay: 1.5s;"></div>
        <div class="particle absolute w-2 h-2 bg-blue-400/30 rounded-full animate-float"
            style="top: 15%; left: 70%; animation-delay: 0.5s;"></div>
    </div>

</section>

<!-- ========================================
     QUICK ACCESS CARDS
     ======================================== -->
<section class="quick-access-section relative py-16 md:py-24 bg-gradient-to-b from-white to-gray-50">
    <div class="container mx-auto px-4">

        <!-- Section Header -->
        <div class="text-center mb-12 md:mb-16" data-aos="fade-up">
            <span
                class="text-green-600 font-bold tracking-widest uppercase text-xs md:text-sm mb-3 block font-space">Quick
                Access</span>
            <h2 class="text-4xl md:text-5xl lg:text-6xl font-black text-gray-900 mb-4 font-outfit">
                <span class="text-gradient">เข้าถึงได้ง่าย</span>
            </h2>
            <div class="w-24 h-1.5 bg-gradient-to-r from-green-500 via-cyan-500 to-blue-500 mx-auto rounded-full"></div>
        </div>

        <!-- Cards Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">
            {% set colors = {
            'green': {'bg': 'from-emerald-600 to-green-700', 'shadow': 'shadow-emerald-500/30', 'border':
            'border-emerald-400/50'},
            'teal': {'bg': 'from-teal-600 to-cyan-700', 'shadow': 'shadow-teal-500/30', 'border': 'border-teal-400/50'},
            'blue': {'bg': 'from-blue-600 to-indigo-700', 'shadow': 'shadow-blue-500/30', 'border':
            'border-blue-400/50'},
            'indigo': {'bg': 'from-indigo-600 to-purple-700', 'shadow': 'shadow-indigo-500/30', 'border':
            'border-indigo-400/50'},
            'red': {'bg': 'from-rose-600 to-red-700', 'shadow': 'shadow-rose-500/30', 'border': 'border-rose-400/50'},
            'orange': {'bg': 'from-orange-600 to-amber-700', 'shadow': 'shadow-orange-500/30', 'border':
            'border-orange-400/50'}
            } %}

            {% for btn in quick_buttons %}
            {% set color = colors[btn.color] if btn.color in colors else {'bg': 'from-zinc-700 to-zinc-900', 'shadow':
            'shadow-zinc-500/30', 'border': 'border-zinc-400/50'} %}

            <a href="{{ btn.url }}" class="quick-card group relative h-56 md:h-72 rounded-3xl overflow-hidden
                      bg-gradient-to-br {{ color.bg }}
                      shadow-2xl {{ color.shadow }}
                      transform transition-all duration-500 hover:-translate-y-3 hover:shadow-3xl
                      border-2 {{ color.border }}
                      gpu" data-aos="fade-up" data-aos-delay="{{ loop.index * 100 }}">

                {% if btn.image %}
                <!-- Background Image -->
                <div class="absolute inset-0 opacity-20 group-hover:opacity-40 group-hover:scale-110 transition-all duration-700 gpu"
                    style="background: url('{{ btn.image }}') center/cover;"></div>
                {% endif %}

                <!-- Gradient Overlay -->
                <div class="absolute inset-0 bg-gradient-to-br from-black/30 via-transparent to-black/50"></div>

                <!-- Content -->
                <div class="relative h-full p-6 md:p-8 flex flex-col justify-between">

                    <!-- Icon -->
                    <div class="w-14 h-14 md:w-16 md:h-16 rounded-2xl glass flex items-center justify-center
                                group-hover:scale-110 group-hover:rotate-12 transition-all duration-300 gpu">
                        <svg class="w-7 h-7 md:w-8 md:h-8 text-white" fill="none" stroke="currentColor"
                            viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                                d="M13 7l5 5m0 0l-5 5m5-5H6" />
                        </svg>
                    </div>

                    <!-- Title -->
                    <div>
                        <h3 class="text-xl md:text-2xl font-bold text-white leading-tight mb-2
                                   group-hover:translate-x-2 transition-transform duration-300">
                            {{ btn.title }}
                        </h3>
                        <div class="w-12 h-1 bg-white/50 rounded-full group-hover:w-20 transition-all duration-300">
                        </div>
                    </div>
                </div>

                <!-- Hover Accent Line -->
                <div
                    class="absolute bottom-0 left-0 w-full h-1.5 bg-white transform scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left">
                </div>
            </a>
            {% endfor %}
        </div>
    </div>
</section>

<!-- ========================================
     FEATURES SECTION
     ======================================== -->
<section
    class="features-section py-20 md:py-32 bg-gradient-to-br from-gray-900 via-slate-900 to-black text-white font-outfit relative overflow-hidden">

    <!-- Background Pattern -->
    <div class="absolute inset-0 opacity-5"
        style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;1&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/svg%3E');">
    </div>

    <div class="container mx-auto px-4 relative z-10">

        <!-- Section Header -->
        <div class="mb-12 md:mb-20" data-aos="fade-up">
            <span
                class="text-green-400 font-bold tracking-widest uppercase text-xs md:text-sm mb-3 block font-space">Our
                Structure</span>
            <h2 class="text-5xl md:text-6xl lg:text-7xl font-black mb-6">
                <span class="text-gradient">สายวิชา</span>
            </h2>
            <div class="w-32 h-2 bg-gradient-to-r from-green-500 via-cyan-500 to-blue-500 rounded-full"></div>
        </div>

        <!-- Features Grid -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12">
            {% for feat in home_features %}
            <div class="feature-card glass-dark rounded-3xl p-8 md:p-10
                        border-l-4 border-green-500/50 hover:border-green-400
                        transform transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl
                        group gpu" data-aos="fade-up" data-aos-delay="{{ loop.index * 150 }}">

                <!-- Icon -->
                <div class="mb-8 relative">
                    <div class="w-16 h-16 md:w-20 md:h-20 rounded-2xl 
                                bg-gradient-to-br from-green-500/20 to-blue-500/20 
                                flex items-center justify-center
                                group-hover:scale-110 group-hover:rotate-6 transition-all duration-300
                                border-2 border-green-400/30 glow-green gpu">
                        <svg class="w-8 h-8 md:w-10 md:h-10 text-green-400" fill="none" stroke="currentColor"
                            viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="{{ feat.icon }}" />
                        </svg>
                    </div>

                    <!-- Decorative Circle -->
                    <div class="absolute -top-2 -right-2 w-6 h-6 border-2 border-cyan-400/50 rounded-full animate-ping">
                    </div>
                </div>

                <!-- Content -->
                <h3 class="text-2xl md:text-3xl font-bold mb-4 group-hover:text-green-400 transition-colors">
                    {{ feat.title }}
                </h3>
                <p class="text-gray-400 leading-relaxed mb-6 text-sm md:text-base">
                    {{ feat.desc }}
                </p>

                <!-- CTA -->
                <a href="{{ feat.url }}"
                    class="inline-flex items-center gap-3 text-sm font-bold uppercase tracking-wider text-white hover:text-green-400 transition-colors group/link">
                    <span>Explore</span>
                    <div class="h-px w-10 bg-current group-hover/link:w-16 transition-all duration-300"></div>
                    <svg class="w-5 h-5 group-hover/link:translate-x-2 transition-transform" fill="none"
                        stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
                    </svg>
                </a>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

<!-- ========================================
     NEWS CAROUSEL
     ======================================== -->
<section class="news-section py-20 md:py-32 bg-white">
    <div class="container mx-auto px-4">

        <!-- Header -->
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-12 md:mb-16"
            data-aos="fade-up">
            <div>
                <span
                    class="text-green-600 font-bold tracking-widest uppercase text-xs md:text-sm mb-3 block font-space">Latest</span>
                <h2 class="text-5xl md:text-6xl lg:text-8xl font-black text-gray-900 mb-4 tracking-tighter font-outfit">
                    Updates
                </h2>
                <div class="w-32 h-2 bg-gradient-to-r from-green-500 to-blue-500 rounded-full"></div>
            </div>

            <a href="/news" class="mt-6 md:mt-0 inline-flex items-center gap-3 px-8 py-4 
                      bg-gray-900 text-white rounded-full
                      hover:bg-green-600 transition-all duration-300
                      shadow-lg hover:shadow-2xl hover:-translate-y-1
                      font-bold uppercase tracking-wide text-sm group gpu">
                <span>View All</span>
                <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor"
                    viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
                </svg>
            </a>
        </div>

        <!-- Swiper Carousel -->
        <div class="swiper newsSwiper" data-aos="fade-up" data-aos-delay="200">
            <div class="swiper-wrapper pb-16">
                {% for item in unified_updates %}
                {% set is_news = item.display_type == 'News' %}

                <div class="swiper-slide h-auto">
                    <a href="/{{ 'news' if is_news else 'activities' }}/{{ item.id }}" class="news-card group block h-full bg-white rounded-3xl overflow-hidden
                              shadow-xl hover:shadow-2xl transition-all duration-500
                              transform hover:-translate-y-2 border border-gray-100 gpu">

                        <!-- Image -->
                        <div class="relative h-56 md:h-72 overflow-hidden bg-gradient-to-br from-green-100 to-blue-100">
                            {% if item.image_url %}
                            <img src="{{ item.image_url }}" alt="{{ item.title }}"
                                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700 gpu">
                            {% else %}
                            <div class="w-full h-full bg-gradient-to-br from-green-400 to-blue-500 opacity-50"></div>
                            {% endif %}

                            <!-- Overlay -->
                            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent">
                            </div>

                            <!-- Category Badge -->
                            <div class="absolute top-4 left-4">
                                <span
                                    class="glass px-4 py-2 rounded-full text-xs font-bold uppercase tracking-wide text-white">
                                    {{ item.category or ('News' if is_news else 'Activity') }}
                                </span>
                            </div>

                            <!-- Date -->
                            <div class="absolute bottom-4 left-4">
                                <span class="glass-dark px-4 py-2 rounded-full text-xs font-bold text-white">
                                    {{ item.created_at.strftime('%d %b %Y') if item.created_at else 'Recent' }}
                                </span>
                            </div>
                        </div>

                        <!-- Content -->
                        <div class="p-6 md:p-8">
                            <h3 class="text-xl md:text-2xl font-bold text-gray-900 leading-tight mb-4
                                       group-hover:text-green-600 transition-colors line-clamp-2">
                                {{ item.title }}
                            </h3>

                            {% if item.content %}
                            <p class="text-gray-600 text-sm md:text-base leading-relaxed line-clamp-3 mb-6">
                                {{ item.content[:120] }}...
                            </p>
                            {% endif %}

                            <!-- Read More -->
                            <div
                                class="flex items-center gap-2 text-sm font-bold text-green-600 group-hover:gap-4 transition-all">
                                <span>Read More</span>
                                <svg class="w-5 h-5 group-hover:translate-x-2 transition-transform" fill="none"
                                    stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                                        d="M9 5l7 7-7 7" />
                                </svg>
                            </div>
                        </div>
                    </a>
                </div>
                {% endfor %}
            </div>

            <!-- Navigation -->
            <div class="swiper-button-next"></div>
            <div class="swiper-button-prev"></div>
            <div class="swiper-pagination"></div>
        </div>
    </div>
</section>

<!-- ========================================
     STATS SECTION
     ======================================== -->
<section
    class="stats-section py-20 md:py-32 bg-gradient-to-br from-gray-900 via-black to-gray-900 text-white relative overflow-hidden">

    <!-- Animated Background -->
    <div class="absolute inset-0 opacity-10">
        <div class="absolute top-20 left-20 w-64 h-64 bg-green-500 rounded-full blur-3xl animate-pulse-glow"></div>
        <div class="absolute bottom-20 right-20 w-80 h-80 bg-blue-500 rounded-full blur-3xl animate-pulse-glow"
            style="animation-delay: 1.5s;"></div>
    </div>

    <div class="container mx-auto px-4 relative z-10">
        <div class="grid grid-cols-2 md:grid-cols-5 gap-8 md:gap-12">
            {% for stat in stats %}
            <div class="stat-item text-center group" data-aos="zoom-in" data-aos-delay="{{ loop.index * 100 }}">
                <div class="stat-number text-4xl md:text-5xl lg:text-7xl font-black mb-4 
                            text-gradient gpu
                            transform group-hover:scale-110 transition-transform duration-300">
                    {{ stat.number }}
                </div>
                <div class="h-px w-16 bg-gradient-to-r from-green-500 to-blue-500 mx-auto mb-4 rounded-full"></div>
                <div class="text-xs md:text-sm uppercase tracking-widest text-gray-400 font-bold font-space px-2">
                    {{ stat.label }}
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

<!-- Scripts -->
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>

{% endblock %}

{% block scripts %}
<script>
    document.addEventListener("DOMContentLoaded", function () {
        // GSAP Setup
        gsap.registerPlugin(ScrollTrigger);

        // ==========================================
        // SWIPER CAROUSEL
        // ==========================================
        const newsSwiper = new Swiper('.newsSwiper', {
            slidesPerView: 1.2,
            spaceBetween: 20,
            grabCursor: true,
            loop: true,
            autoplay: {
                delay: 5000,
                disableOnInteraction: false,
                pauseOnMouseEnter: true
            },
            speed: 800,
            navigation: {
                nextEl: '.swiper-button-next',
                prevEl: '.swiper-button-prev',
            },
            pagination: {
                el: '.swiper-pagination',
                clickable: true,
                dynamicBullets: true
            },
            breakpoints: {
                640: { slidesPerView: 2, spaceBetween: 24 },
                768: { slidesPerView: 2.5, spaceBetween: 30 },
                1024: { slidesPerView: 3, spaceBetween: 32 },
                1280: { slidesPerView: 3.5, spaceBetween: 32 }
            }
        });

        // ==========================================
        // HERO PARALLAX & INTERACTIONS
        // ==========================================

        // Parallax on scroll
        gsap.to(".hero-section video", {
            yPercent: 30,
            ease: "none",
            scrollTrigger: {
                trigger: ".hero-section",
                start: "top top",
                end: "bottom top",
                scrub: 1
            }
        });

        // Letter box 3D tilt on mouse move
        const nredRows = document.querySelectorAll('.nred-row');
        nredRows.forEach((row, index) => {
            row.addEventListener('mousemove', (e) => {
                const rect = row.getBoundingClientRect();
                const x = (e.clientX - rect.left) / rect.width - 0.5;
                const y = (e.clientY - rect.top) / rect.height - 0.5;

                const letterBox = row.querySelector('.letter-box > div');
                gsap.to(letterBox, {
                    rotationY: x * 15,
                    rotationX: -y * 15,
                    duration: 0.3,
                    ease: "power2.out"
                });
            });

            row.addEventListener('mouseleave', () => {
                const letterBox = row.querySelector('.letter-box > div');
                gsap.to(letterBox, {
                    rotationY: 0,
                    rotationX: 0,
                    duration: 0.5,
                    ease: "power2.out"
                });
            });
        });

        // ==========================================
        // SCROLL ANIMATIONS
        // ==========================================

        // Quick Cards
        gsap.from(".quick-card", {
            scrollTrigger: {
                trigger: ".quick-access-section",
                start: "top 80%"
            },
            y: 80,
            opacity: 0,
            duration: 0.8,
            stagger: 0.1,
            ease: "power3.out"
        });

        // Feature Cards
        gsap.from(".feature-card", {
            scrollTrigger: {
                trigger: ".features-section",
                start: "top 75%"
            },
            y: 60,
            opacity: 0,
            duration: 0.8,
            stagger: 0.15,
            ease: "power2.out"
        });

        // ==========================================
        // COUNTER ANIMATION
        // ==========================================
        const statNumbers = document.querySelectorAll('.stat-number');
        statNumbers.forEach(stat => {
            const text = stat.textContent.trim();
            const hasPlus = text.includes('+');
            const numOnly = text.replace(/[^0-9]/g, '');

            if (numOnly) {
                ScrollTrigger.create({
                    trigger: stat,
                    start: "top 85%",
                    onEnter: () => {
                        let count = 0;
                        const target = parseInt(numOnly);
                        const duration = 2000;
                        const increment = target / (duration / 16);

                        const counter = setInterval(() => {
                            count += increment;
                            if (count >= target) {
                                stat.textContent = hasPlus ? target + '+' : target;
                                clearInterval(counter);
                            } else {
                                stat.textContent = Math.floor(count);
                            }
                        }, 16);
                    },
                    once: true
                });
            }
        });

        // ==========================================
        // PERFORMANCE OPTIMIZATIONS
        // ==========================================

        // Lazy load images
        if ('IntersectionObserver' in window) {
            const imageObserver = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        const img = entry.target;
                        if (img.dataset.src) {
                            img.src = img.dataset.src;
                            img.removeAttribute('data-src');
                        }
                        imageObserver.unobserve(img);
                    }
                });
            });

            document.querySelectorAll('img[data-src]').forEach(img => {
                imageObserver.observe(img);
            });
        }

        // Console Easter Egg
        console.log('%c🌱 NRED Department', 'color: #10b981; font-size: 24px; font-weight: bold;');
        console.log('%c✨ Designed with GSAP & Modern Web Tech', 'color: #3b82f6; font-size: 14px;');
    });
</script>
{% endblock %}